<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.postgresql.controllers.UserPanelController"
            prefWidth="1280" prefHeight="800"
            style="-fx-background-color: #f1f5f9;">

    
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: white;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),8,0,0,3);
                     -fx-padding: 0 24 0 24; -fx-min-height: 60; -fx-pref-height: 60;">

            <Label text="Биржа грузоперевозок"
                   style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

            <Region HBox.hgrow="ALWAYS"/>

            
            <Label fx:id="LabelUser" onMouseClicked="#profileClick"
                   style="-fx-font-size: 14; -fx-text-fill: #1e40af; -fx-padding: 0 16 0 0;
                          -fx-cursor: hand; -fx-underline: true;"/>

            <Button text="Выйти" onAction="#goBack"
                    style="-fx-background-color: transparent; -fx-border-color: #1e40af;
                           -fx-border-radius: 8; -fx-text-fill: #1e40af;
                           -fx-font-weight: bold; -fx-padding: 6 16; -fx-cursor: hand;"/>
        </HBox>
    </top>

    
    <center>
        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE"
                 style="-fx-background-color: #f1f5f9; -fx-tab-min-width: 140;">
            <tabs>

                
                <Tab text="📦  Все грузы">
                    <content>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                                    style="-fx-background-color: #f1f5f9; -fx-border-color: transparent;">
                            <VBox spacing="0">

                                
                                <VBox style="-fx-background-color: white; -fx-background-radius: 14;
                                             -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,3);
                                             -fx-padding: 16 20 14 20;">
                                    <VBox.margin><Insets top="14" right="14" bottom="8" left="14"/></VBox.margin>

                                    <Label text="Фильтры поиска"
                                           style="-fx-font-weight: bold; -fx-font-size: 14;
                                                  -fx-text-fill: #1e40af; -fx-padding: 0 0 10 0;"/>

                                    <HBox spacing="12" alignment="CENTER_LEFT">
                                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                                            <Label text="Откуда" style="-fx-font-size: 11; -fx-text-fill: #64748b;"/>
                                            <TextField fx:id="fromFilter" promptText="Например: Москва"
                                                       style="-fx-background-radius: 8; -fx-border-radius: 8;
                                                              -fx-border-color: #e2e8f0; -fx-padding: 7 10; -fx-font-size: 13;"/>
                                        </VBox>
                                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                                            <Label text="Куда" style="-fx-font-size: 11; -fx-text-fill: #64748b;"/>
                                            <TextField fx:id="toFilter" promptText="Например: Казань"
                                                       style="-fx-background-radius: 8; -fx-border-radius: 8;
                                                              -fx-border-color: #e2e8f0; -fx-padding: 7 10; -fx-font-size: 13;"/>
                                        </VBox>
                                        <VBox spacing="3">
                                            <Label text="Вес (тонн)" style="-fx-font-size: 11; -fx-text-fill: #64748b;"/>
                                            <HBox spacing="6" alignment="CENTER_LEFT">
                                                <TextField fx:id="minWeightFilter" promptText="от" prefWidth="68"
                                                           style="-fx-background-radius: 8; -fx-border-radius: 8;
                                                                  -fx-border-color: #e2e8f0; -fx-padding: 7 8; -fx-font-size: 13;"/>
                                                <Label text="—" style="-fx-text-fill: #94a3b8;"/>
                                                <TextField fx:id="maxWeightFilter" promptText="до" prefWidth="68"
                                                           style="-fx-background-radius: 8; -fx-border-radius: 8;
                                                                  -fx-border-color: #e2e8f0; -fx-padding: 7 8; -fx-font-size: 13;"/>
                                            </HBox>
                                        </VBox>
                                        <VBox spacing="3">
                                            <Label text="Цена без НДС (₽)" style="-fx-font-size: 11; -fx-text-fill: #64748b;"/>
                                            <HBox spacing="6" alignment="CENTER_LEFT">
                                                <TextField fx:id="minPriceFilter" promptText="от" prefWidth="78"
                                                           style="-fx-background-radius: 8; -fx-border-radius: 8;
                                                                  -fx-border-color: #e2e8f0; -fx-padding: 7 8; -fx-font-size: 13;"/>
                                                <Label text="—" style="-fx-text-fill: #94a3b8;"/>
                                                <TextField fx:id="maxPriceFilter" promptText="до" prefWidth="78"
                                                           style="-fx-background-radius: 8; -fx-border-radius: 8;
                                                                  -fx-border-color: #e2e8f0; -fx-padding: 7 8; -fx-font-size: 13;"/>
                                            </HBox>
                                        </VBox>
                                        <VBox alignment="BOTTOM_LEFT" spacing="3">
                                            <Label text=" " style="-fx-font-size: 11;"/>
                                            <Button fx:id="applyFilterButton" text="Найти"
                                                    style="-fx-background-color: #1e40af; -fx-text-fill: white;
                                                           -fx-font-weight: bold; -fx-padding: 7 20;
                                                           -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13;"/>
                                        </VBox>
                                    </HBox>
                                </VBox>

                                
                                <VBox fx:id="cargoContainer" spacing="8">
                                    <VBox.margin><Insets top="8" right="14" bottom="14" left="14"/></VBox.margin>
                                </VBox>
                            </VBox>
                        </ScrollPane>
                    </content>
                </Tab>

                
                <Tab text="🚚  Мои грузы">
                    <content>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                                    style="-fx-background-color: #f1f5f9; -fx-border-color: transparent;">
                            <VBox fx:id="userCargoContainer" spacing="8">
                                <VBox.margin><Insets top="14" right="14" bottom="14" left="14"/></VBox.margin>
                                <Button fx:id="btnAddCargo" text="+ Добавить груз"
                                        onAction="#addUsersCargo"
                                        style="-fx-background-color: #1e40af; -fx-text-fill: white;
                                               -fx-font-weight: bold; -fx-font-size: 13;
                                               -fx-padding: 9 24; -fx-background-radius: 10;
                                               -fx-cursor: hand;"/>
                            </VBox>
                        </ScrollPane>
                    </content>
                </Tab>

                
                <Tab text="★  Избранное">
                    <content>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                                    style="-fx-background-color: #f1f5f9; -fx-border-color: transparent;">
                            <VBox fx:id="favoritesContainer" spacing="8">
                                <VBox.margin><Insets top="14" right="14" bottom="14" left="14"/></VBox.margin>
                            </VBox>
                        </ScrollPane>
                    </content>
                </Tab>

                
                <Tab text="💬  Чат">
                    <content>
                        
                        <AnchorPane style="-fx-background-color: #f1f5f9;">
                        
                        <HBox style="-fx-background-color: #f1f5f9;"
                              AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                              AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

                            
                            <VBox prefWidth="300" minWidth="260" maxWidth="340"
                                  style="-fx-background-color: white;
                                         -fx-border-color: #e2e8f0; -fx-border-width: 0 1 0 0;">

                                <Label text="💬  Чаты"
                                       style="-fx-font-weight: bold; -fx-font-size: 16;
                                              -fx-text-fill: #0f172a; -fx-padding: 18 16 12 18;"/>

                                <Separator/>

                                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                                            style="-fx-border-color: transparent; -fx-background-color: transparent;">
                                    <VBox fx:id="chatListContainer" spacing="0"/>
                                </ScrollPane>
                            </VBox>

                            
                            <VBox fx:id="chatContentPane" HBox.hgrow="ALWAYS"
                                  alignment="CENTER"
                                  style="-fx-background-color: #f8fafc;">

                                
                                <VBox fx:id="chatPlaceholder" alignment="CENTER" spacing="12"
                                      VBox.vgrow="ALWAYS">
                                    <Label text="💬"
                                           style="-fx-font-size: 52; -fx-text-fill: #cbd5e1;"/>
                                    <Label text="Выберите чат слева"
                                           style="-fx-font-size: 16; -fx-text-fill: #94a3b8; -fx-font-weight: bold;"/>
                                    <Label text="или нажмите «Написать» на карточке груза"
                                           style="-fx-font-size: 13; -fx-text-fill: #cbd5e1;"/>
                                </VBox>

                            </VBox>
                        </HBox>
                        </AnchorPane>
                    </content>
                </Tab>

            </tabs>
        </TabPane>
    </center>

</BorderPane>

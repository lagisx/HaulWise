<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="760.0" prefWidth="1100.0" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.postgresql.Controllers.UserPanelController">

    <children>

        <!-- Шапка приложения -->
        <VBox AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <HBox alignment="CENTER_LEFT" prefHeight="76.0" spacing="20" style="-fx-background: linear-gradient(to right, #1e40af, #3b82f6); -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 12, 0, 0, 6);">
                <padding>
                    <Insets bottom="12" left="30" right="30" top="12" />
                </padding>

                <children>
                    <Label text="Биржа грузоперевозок">
                        <font>
                            <Font name="System Bold" size="26" />
                        </font>
                    </Label>

                    <Region HBox.hgrow="ALWAYS" />

                    <Label fx:id="LabelUser" onMouseClicked="#profileClick" style="-fx-font-size: 16px; -fx-cursor: hand;" text="Пользователь" />

                    <Button onAction="#goBack" style="-fx-background-color: white; -fx-text-fill: #1e40af; -fx-font-weight: bold; -fx-font-size: 14px;                                    -fx-padding: 10 24; -fx-background-radius: 12; -fx-border-color: #60a5fa; -fx-border-width: 2; -fx-border-radius: 12;                                    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 4, 0, 0, 2); -fx-cursor: hand;" text="Выйти" />
                </children>
            </HBox>

            <HBox prefHeight="4.0" style="-fx-background-color: #60a5fa;">
                <children>
                    <Region prefWidth="180" />
                    <Region prefWidth="120" style="-fx-background-color: #fbbf24;" />
                </children>
            </HBox>
        </VBox>

        <!-- Основные вкладки -->
        <TabPane fx:id="tabPane" style="-fx-background-color: transparent;" tabClosingPolicy="UNAVAILABLE" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="80.0">

            <tabs>

                <!-- Вкладка: Все грузы -->
                <Tab>
                    <graphic>
                        <Text style="-fx-font-size: 15px; -fx-font-weight: bold;" text="🚚 Все грузы" />
                    </graphic>
                    <content>
                        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background: #f8fafc; -fx-border-color: transparent;">
                            <content>
                                <VBox spacing="30" style="-fx-padding: 30 40 60 40; -fx-background-color: #f8fafc;">

                                    <!-- Красивая карточка с фильтрами -->
                                    <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 20;                                                          -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 8);">

                                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e40af;" text="Фильтры поиска" />

                                        <GridPane hgap="20" vgap="15">
                                            <columnConstraints>
                                                <ColumnConstraints percentWidth="28" />
                                                <ColumnConstraints percentWidth="28" />
                                                <ColumnConstraints percentWidth="22" />
                                                <ColumnConstraints percentWidth="22" />
                                            </columnConstraints>

                                            <!-- Откуда и Куда -->
                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #374151;" text="Откуда" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                            <TextField fx:id="fromFilter" promptText="Например: Москва" style="-fx-background-radius: 12; -fx-padding: 12; -fx-font-size: 14; -fx-pref-width: 200;                                                               -fx-background-color: #f1f5f9; -fx-border-color: #cbd5e1; -fx-border-radius: 12;" GridPane.columnIndex="0" GridPane.rowIndex="1" />

                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #374151;" text="Куда" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                            <TextField fx:id="toFilter" promptText="Например: Екатеринбург" style="-fx-background-radius: 12; -fx-padding: 12; -fx-font-size: 14; -fx-pref-width: 200;                                                               -fx-background-color: #f1f5f9; -fx-border-color: #cbd5e1; -fx-border-radius: 12;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                            <!-- Вес -->
                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #374151;" text="Вес (тонн)" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                            <HBox alignment="CENTER_LEFT" spacing="10" GridPane.columnIndex="2" GridPane.rowIndex="1">
                                                <TextField fx:id="minWeightFilter" prefWidth="90" promptText="от" style="-fx-background-radius: 12; -fx-padding: 12; -fx-font-size: 14; -fx-text-alignment: center;                                                                   -fx-background-color: #f1f5f9; -fx-border-color: #cbd5e1; -fx-border-radius: 12;" />
                                                <Label style="-fx-font-size: 18; -fx-text-fill: #94a3b8;" text="—" />
                                                <TextField fx:id="maxWeightFilter" prefWidth="90" promptText="до" style="-fx-background-radius: 12; -fx-padding: 12; -fx-font-size: 14; -fx-text-alignment: center;                                                                   -fx-background-color: #f1f5f9; -fx-border-color: #cbd5e1; -fx-border-radius: 12;" />
                                            </HBox>

                                            <!-- Цена -->
                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #374151;" text="Цена по НДС (₽)" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                                            <HBox alignment="CENTER_LEFT" spacing="10" GridPane.columnIndex="3" GridPane.rowIndex="1">
                                                <TextField fx:id="minPriceFilter" prefWidth="90" promptText="от" style="-fx-background-radius: 12; -fx-padding: 12; -fx-font-size: 14; -fx-text-alignment: center;                                                                   -fx-background-color: #f1f5f9; -fx-border-color: #cbd5e1; -fx-border-radius: 12;" />
                                                <Label style="-fx-font-size: 18; -fx-text-fill: #94a3b8;" text="—" />
                                                <TextField fx:id="maxPriceFilter" prefWidth="90" promptText="до" style="-fx-background-radius: 12; -fx-padding: 12; -fx-font-size: 14; -fx-text-alignment: center;                                                                   -fx-background-color: #f1f5f9; -fx-border-color: #cbd5e1; -fx-border-radius: 12;" />
                                            </HBox>
                                 <rowConstraints>
                                    <RowConstraints />
                                    <RowConstraints />
                                 </rowConstraints>
                                        </GridPane>


                                        <HBox alignment="CENTER_RIGHT">
                                            <Button fx:id="applyFilterButton" style="-fx-background-color: white; -fx-text-fill: #1e40af; -fx-font-weight: bold; -fx-font-size: 12px; -fx-padding: 8 2; -fx-background-radius: 12; -fx-border-color: #60a5fa; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 4, 0, 0, 2); -fx-cursor: hand;" styleClass="filter-apply-button" text="Применить фильтры">
                                    <font>
                                       <Font size="10.0" />
                                    </font></Button>
                                        </HBox>
                                    </VBox>

                                    <VBox fx:id="cargoContainer" spacing="20" />

                                </VBox>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>

                <Tab>
                    <graphic>
                        <Text style="-fx-font-size: 15px; -fx-font-weight: bold;" text="Мои грузы" />
                    </graphic>
                    <content>
                        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background: #f8fafc; -fx-border-color: transparent;">
                            <content>
                                <VBox fx:id="userCargoContainer" spacing="20" style="-fx-padding: 30 40 50 40; -fx-background-color: #f8fafc;">

                                    <Button fx:id="btnAddCargo" alignment="CENTER" onAction="#AddUsersCargo" style="-fx-background-color: #86efac; -fx-text-fill: #166534; -fx-font-weight: bold; -fx-font-size: 14px;                                                    -fx-padding: 12 36; -fx-background-radius: 12;                                                    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 4, 0, 0, 2); -fx-cursor: hand;" text="Добавить груз" />

                                    <Region VBox.vgrow="ALWAYS" />
                                </VBox>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>

            </tabs>
        </TabPane>

    </children>
</AnchorPane>

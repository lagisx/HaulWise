<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="400" prefWidth="700"
            style="-fx-background-color: #f8fafc;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.postgresql.controllers.PasswordRecoverController">

    <VBox alignment="CENTER" spacing="32" AnchorPane.topAnchor="60" AnchorPane.bottomAnchor="60"
          AnchorPane.leftAnchor="80" AnchorPane.rightAnchor="80">

        <Label style="-fx-font-size: 48px;" text="📧"/>

        <Label text="Письмо отправлено!"
               style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: #1e293b;"/>

        <Label fx:id="statusLabel" alignment="CENTER" prefWidth="500"
               style="-fx-font-size: 16px; -fx-text-fill: #374151;" wrapText="true"/>

        <Label text="Не получили письмо? Проверьте папку «Спам»."
               style="-fx-font-size: 13px; -fx-text-fill: #94a3b8;" wrapText="true"/>

        <Button onAction="#goBack" prefHeight="50" prefWidth="280"
                text="← На страницу входа"
                style="-fx-background-color: #1e3a8a; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-font-size: 16px;
                       -fx-background-radius: 16; -fx-cursor: hand;"/>
    </VBox>
</AnchorPane>

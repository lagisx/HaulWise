<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<AnchorPane prefHeight="140.0" prefWidth="900.0"
            style="-fx-background-color: white; -fx-background-radius: 12;
                   -fx-border-color: #e2e8f0; -fx-border-radius: 12;
                   -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0.08, 0, 3);"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.postgresql.Controllers.CardControllers.UserCargoCardController">

    
    <HBox spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        
        <VBox spacing="6" HBox.hgrow="ALWAYS"
              style="-fx-padding: 12 16 10 16;">

            
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label fx:id="typeLabel"
                       style="-fx-font-size: 12px; -fx-font-weight: 800; -fx-text-fill: #1e40af;
                              -fx-background-color: #eff6ff; -fx-padding: 2 8; -fx-background-radius: 6;"
                       text="Тент"/>
                <Label style="-fx-font-size: 16px; -fx-text-fill: #93c5fd; -fx-font-weight: bold;" text="→"/>
                <Label fx:id="routeLabel"
                       style="-fx-font-size: 15px; -fx-font-weight: 800; -fx-text-fill: #0f172a; -fx-cursor: hand;"
                       text="Москва → Санкт-Петербург"/>
            </HBox>

            
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label fx:id="vesObemLabel"
                       style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #334155;"
                       text="20 т • 82 м³"/>
                <Label style="-fx-text-fill: #cbd5e1; -fx-font-size: 12;" text="•"/>
                <Label fx:id="tovarLabel"
                       style="-fx-font-size: 13px; -fx-text-fill: #475569;"
                       text="Стройматериалы"/>
                <Label style="-fx-text-fill: #cbd5e1; -fx-font-size: 12;" text="•"/>
                <Label fx:id="dateValue"
                       style="-fx-font-size: 11px; -fx-font-weight: 700;
                              -fx-background-color: #dbeafe; -fx-text-fill: #1e40af;
                              -fx-padding: 3 8; -fx-background-radius: 6;"
                       text="25–30.11"/>
                <Label fx:id="cargoTypeLabel"
                       style="-fx-font-size: 11px; -fx-font-weight: 700;
                              -fx-background-color: #fef3c7; -fx-text-fill: #92400e;
                              -fx-padding: 3 8; -fx-background-radius: 6;"
                       text="Боковая"/>
            </HBox>

            
            <HBox alignment="CENTER_LEFT" spacing="10">
                <VBox spacing="1">
                    <Label style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" text="без НДС"/>
                    <Label fx:id="priceKartaLabel"
                           style="-fx-font-size: 13px; -fx-font-weight: 800;
                                  -fx-background-color: #f0fdf4; -fx-text-fill: #16a34a;
                                  -fx-padding: 3 8; -fx-background-radius: 8;"
                           text="150 000 ₽"/>
                </VBox>
                <VBox spacing="1">
                    <Label style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" text="с НДС"/>
                    <Label fx:id="priceNDSLabel"
                           style="-fx-font-size: 13px; -fx-font-weight: 800;
                                  -fx-background-color: #f0f9ff; -fx-text-fill: #0369a1;
                                  -fx-padding: 3 8; -fx-background-radius: 8;"
                           text="180 000 ₽"/>
                </VBox>
                <Label fx:id="contactLabel"
                       style="-fx-font-size: 12px; -fx-font-weight: 600; -fx-text-fill: #16a34a;"
                       text="+7 (999) 123-45-67"/>
                <Label fx:id="tradeLabel"
                       style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"
                       text="Торг возможен"/>
            </HBox>

            
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Button fx:id="chatButton" text="💬 Написать"
                        managed="false" visible="false"
                        style="-fx-background-color: #1e40af; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-font-size: 11px;
                               -fx-padding: 5 14; -fx-background-radius: 8; -fx-cursor: hand;"/>
                <Button fx:id="favButton" text="★ В избранное"
                        managed="false" visible="false"
                        style="-fx-background-color: #fffbeb; -fx-text-fill: #92400e;
                               -fx-font-weight: bold; -fx-font-size: 11px;
                               -fx-padding: 5 14; -fx-background-radius: 8;
                               -fx-border-color: #fde68a; -fx-border-radius: 8; -fx-cursor: hand;"/>
                <Label fx:id="deleteLabel" managed="false" visible="false"
                       style="-fx-font-size: 12px; -fx-text-fill: #ef4444;
                              -fx-font-weight: bold; -fx-cursor: hand;
                              -fx-background-color: #fff1f2;
                              -fx-background-radius: 8; -fx-padding: 4 12;"
                       text="✕ Удалить"/>
            </HBox>
        </VBox>

        
        <ImageView fx:id="randomImageOnCard"
                   fitHeight="120.0" fitWidth="150.0"
                   preserveRatio="true"
                   visible="false"
                   style="-fx-padding: 10 14 10 0;">
            <clip><Rectangle arcHeight="12" arcWidth="12" height="100" width="140"/></clip>
        </ImageView>

    </HBox>
</AnchorPane>

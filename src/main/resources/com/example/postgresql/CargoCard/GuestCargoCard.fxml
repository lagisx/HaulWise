<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.shape.Rectangle?>

<AnchorPane prefHeight="140.0" prefWidth="920.0"
            style="-fx-background-color: white; -fx-background-radius: 14;
                   -fx-border-color: #e2e8f0; -fx-border-radius: 14;
                   -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0.10, 0, 4);"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.postgresql.controllers.CardControllers.GuestCargoCardController">

    <VBox spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        
        <HBox spacing="0" VBox.vgrow="ALWAYS">

            
            <VBox spacing="7" HBox.hgrow="ALWAYS">
                <padding><Insets top="14" right="16" bottom="10" left="20"/></padding>

                
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="typeLabel"
                           style="-fx-font-size: 13px; -fx-font-weight: 800; -fx-text-fill: #1d4ed8;
                                  -fx-background-color: #eff6ff; -fx-padding: 2 10; -fx-background-radius: 6;"
                           text="RUS • Тент"/>
                    <Label style="-fx-font-size: 20px; -fx-text-fill: #3b82f6; -fx-font-weight: bold;" text="→"/>
                    <Label fx:id="routeLabel"
                           style="-fx-font-size: 16px; -fx-font-weight: 900; -fx-text-fill: #0f172a; -fx-cursor: hand;"
                           text="Москва → СПб"/>
                </HBox>

                
                <HBox alignment="CENTER_LEFT" spacing="14">
                    <Label fx:id="vesObemLabel"
                           style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #1e293b;"
                           text="20 т • 82 м³"/>
                    <Label style="-fx-text-fill: #cbd5e1; -fx-font-size: 13;" text="•"/>
                    <Label fx:id="tovarLabel"
                           style="-fx-font-size: 13px; -fx-text-fill: #64748b;"
                           text="Стройматериалы"/>
                </HBox>

                
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="zagruzValue"
                           style="-fx-font-size: 12px; -fx-font-weight: 600; -fx-text-fill: #475569;"
                           text="Боковая"/>
                    <Label fx:id="dateValue"
                           style="-fx-font-size: 12px; -fx-font-weight: 700;
                                  -fx-background-color: #dbeafe; -fx-text-fill: #1e40af;
                                  -fx-padding: 3 10; -fx-background-radius: 8;"
                           text="25.11 – 30.11"/>
                    <Label fx:id="cargoTypeLabel"
                           style="-fx-font-size: 12px; -fx-font-weight: 700;
                                  -fx-background-color: #fef3c7; -fx-text-fill: #92400e;
                                  -fx-padding: 3 10; -fx-background-radius: 8;"
                           text="Гидроборт"/>
                </HBox>
            </VBox>

            
            <ImageView fx:id="randomImageOnCard"
                       fitHeight="130.0" fitWidth="170.0"
                       preserveRatio="true"
                       visible="false"
                       style="-fx-padding: 8 14 8 0;">
                <clip><Rectangle arcHeight="12" arcWidth="12" height="120" width="160"/></clip>
            </ImageView>

        </HBox>

        
        <HBox alignment="CENTER_LEFT" spacing="10"
              style="-fx-background-color: #fffbeb; -fx-background-radius: 0 0 14 14;
                     -fx-padding: 8 20;">
            <Label fx:id="priceHidden"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #dc2626;"
                   text="Цена скрыта"/>
            <Label style="-fx-text-fill: #fcd34d;" text="•"/>
            <Label fx:id="contactLabel"
                   style="-fx-font-size: 12px; -fx-text-fill: #92400e;"
                   text="Войдите, чтобы увидеть контакты"/>
        </HBox>

    </VBox>
</AnchorPane>

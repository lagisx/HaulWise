<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="620" prefWidth="880" style="-fx-background-color: #f6f7f9;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.example.postgresql.Controllers.HelloController">
    <children>

        
        <AnchorPane prefHeight="620" prefWidth="760">
            <children>
                <SVGPath content="M0,0 L390,0 Q530,310 390,620 L0,620 Z" fill="#1e3b8a" stroke="transparent" />
                <Label layoutX="261.0" layoutY="26.0" style="-fx-text-fill: white; -fx-font-size: 42px; -fx-font-weight: bold;" text="Биржа" />
                <Label layoutX="426.0" layoutY="26.0" style="-fx-text-fill: #111827; -fx-font-size: 42px; -fx-font-weight: bold;" text="грузоперевозок" />
            </children>
        </AnchorPane>

        
        <VBox layoutX="52" layoutY="180" spacing="6">
            <Label style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: bold;" text="Авторизируйтесь" />
            <Label style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: bold;" text="в личном" />
            <Label style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: bold;" text="кабинете" />
        </VBox>

        
        <AnchorPane layoutX="476" layoutY="94.0" prefHeight="454.0" prefWidth="370" style="-fx-background-color: white; -fx-background-radius: 20;                            -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.18),14,0,0,4);">
            <children>
                <Label layoutX="88" layoutY="26" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="Вход в систему" />

                
                <Label layoutX="52" layoutY="76" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;" text="Логин или Email" />
                <TextField fx:id="username" layoutX="52" layoutY="96" prefHeight="38" prefWidth="266" promptText="Введите логин или email" style="-fx-background-radius:8;-fx-border-radius:8;                                   -fx-border-color:#cbd5e1;-fx-font-size:13px;" />

                
                <Label layoutX="52" layoutY="146" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;" text="Пароль" />
                <StackPane fx:id="passwordTextField" layoutX="54" layoutY="166" prefHeight="38" prefWidth="266">
                    <children>
                        <TextField fx:id="passVisible" managed="false" prefHeight="36" prefWidth="256" promptText="Пароль" style="-fx-background-radius:8;-fx-border-radius:8;                                           -fx-border-color:#cbd5e1;-fx-font-size:13px;" visible="false" />
                        <PasswordField fx:id="password" prefHeight="36" prefWidth="256" promptText="Введите пароль" style="-fx-background-radius:8;-fx-border-radius:8;                                               -fx-border-color:#cbd5e1;-fx-font-size:13px;" />
                    </children>
                </StackPane>
                <Button fx:id="PassInTexts" focusTraversable="false" layoutX="316" layoutY="172" onAction="#PassInText" prefHeight="26" prefWidth="28" style="-fx-background-color:transparent;-fx-cursor:hand;" text="👀">
                    <font><Font size="12" /></font>
                </Button>

                
                <Hyperlink layoutX="52" layoutY="214" onAction="#showForgetPass" style="-fx-font-size:12px;-fx-text-fill:#374151;" text="Забыли пароль?" />
                <Hyperlink layoutX="240" layoutY="214" onAction="#showRegs" style="-fx-font-size:12px;-fx-text-fill:#374151;" text="Регистрация" />

                
                <Button layoutX="85" layoutY="252" onAction="#Connect" prefHeight="40" prefWidth="200" style="-fx-background-color:#1e3a8a;-fx-text-fill:white;                                -fx-font-weight:bold;-fx-font-size:14px;                                -fx-background-radius:10;-fx-cursor:hand;" text="Войти" />

                
                <Hyperlink layoutX="132" layoutY="304" onAction="#goGuestPanel" style="-fx-font-size:12px;-fx-text-fill:#374151;" text="Зайти как гость" />

                
                <TextFlow fx:id="statusFlow" layoutX="10" layoutY="334" prefHeight="130" prefWidth="350" textAlignment="CENTER">
                    <children>
                        <Label fx:id="statusLabel" alignment="CENTER" style="-fx-font-size:12px;-fx-text-fill:red;-fx-font-weight:bold;" textAlignment="CENTER" wrapText="true" />
                    </children>
                </TextFlow>
            </children>
        </AnchorPane>

    </children>
</AnchorPane>

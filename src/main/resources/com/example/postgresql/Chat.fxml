<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.postgresql.controllers.ChatController"
      prefWidth="600" prefHeight="640"
      style="-fx-background-color: #f8fafc;">

    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: white;
                 -fx-padding: 14 20;
                 -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
        <Label style="-fx-font-size: 20px;" text="💬"/>
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label fx:id="chatTitleLabel"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"
                   text="Чат"/>
            <Label fx:id="partnerPhoneLabel"
                   style="-fx-font-size: 12px; -fx-text-fill: #16a34a; -fx-font-weight: 600;"
                   text=""/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox fx:id="dealButtonsBox" spacing="8" alignment="CENTER_RIGHT"
              visible="false" managed="false">
            <Button fx:id="completeDealBtn" text="✅ Завершить сделку"
                    onAction="#onCompleteDeal"
                    style="-fx-background-color: #16a34a; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-font-size: 11px;
                           -fx-padding: 6 14; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button fx:id="cancelDealBtn2" text="✕ Отменить"
                    onAction="#onCancelDeal"
                    style="-fx-background-color: #fff1f2; -fx-text-fill: #ef4444;
                           -fx-font-weight: bold; -fx-font-size: 11px;
                           -fx-padding: 6 14; -fx-background-radius: 8;
                           -fx-border-color: #fecaca; -fx-border-radius: 8; -fx-cursor: hand;"/>
        </HBox>
    </HBox>

    <HBox fx:id="cargoSwitcherBox" spacing="6" alignment="CENTER_LEFT"
          visible="false" managed="false"
          style="-fx-background-color: #f8fafc; -fx-padding: 8 20;
                 -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
        <Label text="📦 Грузы:" style="-fx-font-size: 11; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
        <ScrollPane fitToHeight="true" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                    HBox.hgrow="ALWAYS" prefHeight="34"
                    style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
            <HBox fx:id="cargoTabsContainer" spacing="6" alignment="CENTER_LEFT"
                  style="-fx-padding: 2 0;"/>
        </ScrollPane>
    </HBox>

    <HBox fx:id="cargoInfoBox" spacing="8" alignment="CENTER_LEFT"
          visible="false" managed="false"
          style="-fx-background-color: #eff6ff; -fx-padding: 8 20;
                 -fx-border-color: #bfdbfe; -fx-border-width: 0 0 1 0;">
        <Label text="📦" style="-fx-font-size: 14;"/>
        <Label fx:id="cargoInfoLabel"
               style="-fx-font-size: 12; -fx-text-fill: #1e40af; -fx-font-weight: bold;"
               text=""/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="dealStatusLabel" style="-fx-font-size: 11; -fx-text-fill: #64748b;"/>
    </HBox>

    <ScrollPane fx:id="scrollPane" fitToWidth="true" hbarPolicy="NEVER"
                VBox.vgrow="ALWAYS"
                style="-fx-background-color: #f1f5f9; -fx-border-color: transparent;">
        <VBox fx:id="messagesContainer" spacing="6"
              style="-fx-padding: 14 0 14 0; -fx-background-color: #f1f5f9;"/>
    </ScrollPane>

    <HBox alignment="CENTER" spacing="10"
          style="-fx-background-color: white; -fx-padding: 10 16;
                 -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0;">
        <TextField fx:id="messageInput"
                   promptText="Введите сообщение..."
                   style="-fx-background-radius: 20; -fx-padding: 9 16;
                          -fx-font-size: 13px; -fx-background-color: #f1f5f9;
                          -fx-border-color: #cbd5e1; -fx-border-radius: 20;"
                   HBox.hgrow="ALWAYS"/>
        <Button fx:id="sendButton" text="↑"
                style="-fx-background-color: #1e40af; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-font-size: 16px;
                       -fx-padding: 8 16; -fx-background-radius: 20; -fx-cursor: hand;"/>
    </HBox>

</VBox>

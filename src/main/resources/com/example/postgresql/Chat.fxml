<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.postgresql.Controllers.ChatController"
      prefWidth="600" prefHeight="580"
      style="-fx-background-color: #f8fafc;">

    
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: white;
                 -fx-padding: 14 20;
                 -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
        <Label style="-fx-font-size: 20px;" text="💬"/>
        <Label fx:id="chatTitleLabel"
               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"
               text="Чат"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="partnerPhoneLabel"
               style="-fx-font-size: 13px; -fx-text-fill: #16a34a; -fx-font-weight: 600;"
               text=""/>
    </HBox>

    
    <ScrollPane fx:id="scrollPane" fitToWidth="true" hbarPolicy="NEVER"
                VBox.vgrow="ALWAYS"
                style="-fx-background-color: #f1f5f9; -fx-border-color: transparent;">
        <VBox fx:id="messagesContainer" spacing="6"
              style="-fx-padding: 14 0 14 0; -fx-background-color: #f1f5f9;"/>
    </ScrollPane>

    
    <HBox alignment="CENTER" spacing="10"
          style="-fx-background-color: white; -fx-padding: 10 16;
                 -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0;">
        <TextField fx:id="messageInput"
                   promptText="Введите сообщение..."
                   style="-fx-background-radius: 20; -fx-padding: 9 16;
                          -fx-font-size: 13px; -fx-background-color: #f1f5f9;
                          -fx-border-color: #cbd5e1; -fx-border-radius: 20;"
                   HBox.hgrow="ALWAYS"/>
        <Button fx:id="sendButton" text="↑"
                style="-fx-background-color: #1e40af; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-font-size: 16px;
                       -fx-padding: 8 16; -fx-background-radius: 20; -fx-cursor: hand;"/>
    </HBox>

</VBox>

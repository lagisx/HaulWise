<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700" prefWidth="950" style="-fx-background-color: linear-gradient(to bottom right, #f3f4f6, #ffffff);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.postgresql.support.AgreementPanelController">
   <VBox prefHeight="80.0" prefWidth="950.0">
      <children>
         <HBox alignment="CENTER_LEFT" prefHeight="76.0" spacing="20" style="-fx-background: linear-gradient(to right, #1e40af, #3b82f6);                          -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 12, 0, 0, 6);">
            <padding>
               <Insets bottom="12" left="30" right="30" top="12" />
            </padding>
            <children>
               <Label style="-fx-font-size: 26px; -fx-font-weight: 900; -fx-text-fill: black;" text="Пользовательское соглашение">
                  <font>
                     <Font name="System Bold" size="26" />
                  </font>
               </Label>
               <Region HBox.hgrow="ALWAYS" />
               <Button fx:id="logoutButton" onAction="#goBack" style="-fx-background-color: white; -fx-text-fill: #1e40af;                                    -fx-font-weight: bold; -fx-font-size: 14px;                                    -fx-padding: 10 24; -fx-background-radius: 12;                                    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 4, 0, 0, 2);                                    -fx-border-color: #60a5fa; -fx-border-width: 2; -fx-border-radius: 12;                                    -fx-cursor: hand;" text="Выйти" />
            </children>
         </HBox>
         <HBox prefHeight="4.0" style="-fx-background-color: #60a5fa;">
            <children>
               <Region prefWidth="180" />
               <Region prefWidth="120" style="-fx-background-color: #fbbf24;" />
            </children>
         </HBox>
      </children>
   </VBox>

    <ScrollPane fitToWidth="true" layoutY="80" prefHeight="589.0" prefWidth="913.0" style="-fx-background-color: transparent; -fx-padding: 30;" AnchorPane.bottomAnchor="25" AnchorPane.leftAnchor="25" AnchorPane.rightAnchor="12.0">
        <content>
            <VBox alignment="TOP_LEFT" spacing="18" style="-fx-background-color: white;                                                           -fx-background-radius: 16;                                                           -fx-padding: 35;                                                           -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">
                <Label style="-fx-font-size: 16; -fx-text-fill: #111827;" text="Администрация Биржи грузоперевозок (далее — «Администрация») предоставляет право пользоваться сайтом после регистрации." wrapText="true" />
                <Label style="-fx-font-size: 16; -fx-text-fill: #111827;" text="Регистрация осуществляется путём заполнения формы и подтверждения согласия с условиями настоящего Соглашения." wrapText="true" />

                <Label style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: Black;" text="1. Термины" />
                <Label style="-fx-font-size: 16; -fx-text-fill: #111827;" text="- Сайт — веб-ресурс Биржи грузоперевозок." wrapText="true" />
                <Label style="-fx-font-size: 16; -fx-text-fill: #111827;" text="- Участник — зарегистрированное лицо с аккаунтом на сайте." wrapText="true" />
                <Label style="-fx-font-size: 16; -fx-text-fill: #111827;" text="- Аккаунт — данные о пользователе, включая логин, пароль и информацию, размещаемую на сайте." wrapText="true" />
                <Label style="-fx-font-size: 16; -fx-text-fill: #111827;" text="- Сервисы — функционал сайта, включая размещение информации о грузах, поиск перевозчиков, оформление заказов." wrapText="true" />

                <Label style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: black;" text="2. Предмет соглашения" />
                <Label style="-fx-font-size: 16; -fx-text-fill: #111827;" text="Администрация предоставляет участнику право:" wrapText="true" />
                <Label style="-fx-font-size: 16; -fx-text-fill: #111827;" text="- просматривать информацию в приложении;" wrapText="true" />
                <Label style="-fx-font-size: 16; -fx-text-fill: #111827;" text="- размещать информацию о грузах;" wrapText="true" />
                <Label style="-fx-font-size: 16; -fx-text-fill: #111827;" text="- пользоваться сервисами приложения;" wrapText="true" />
                <Label style="-fx-font-size: 16; -fx-text-fill: #111827;" text="- использовать сайт в рамках правил." wrapText="true" />

                <Label style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: black;" text="3. Права и обязанности сторон" />
                <Label style="-fx-font-size: 16; -fx-text-fill: #111827;" text="Администрация обязуется:" wrapText="true" />
                <Label style="-fx-font-size: 16; -fx-text-fill: #111827;" text="- предоставлять доступ к сайту;" wrapText="true" />
                <Label style="-fx-font-size: 16; -fx-text-fill: #111827;" text="- обеспечивать работу сервисов;" wrapText="true" />
                <Label style="-fx-font-size: 16; -fx-text-fill: #111827;" text="- защищать персональные данные участников." wrapText="true" />

                <Label style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: black;" text="4. Права участника" />
                <Label style="-fx-font-size: 16; -fx-text-fill: #111827;" text="- пользоваться функционалом сайта;" wrapText="true" />
                <Label style="-fx-font-size: 16; -fx-text-fill: #111827;" text="- получать информацию о доступных грузах и перевозчиках;" wrapText="true" />
                <Label style="-fx-font-size: 16; -fx-text-fill: #111827;" text="- участвовать в рейтингах и оставлять отзывы." wrapText="true" />

                <Label style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: black;" text="5. Персональные данные" />
                <Label style="-fx-font-size: 16; -fx-text-fill: #111827;" text="Участник даёт согласие на обработку своих данных. Администрация обязуется защищать данные от несанкционированного доступа." wrapText="true" />

                <Label style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: black;" text="6. Использование аккаунта" />
                <Label style="-fx-font-size: 16; -fx-text-fill: #111827;" text="Доступ к сайту возможен только через регистрацию. Аккаунт может быть заблокирован или удалён при нарушении правил." wrapText="true" />

                <Label style="-fx-font-size: 16; -fx-text-fill: #111827;" text="Настоящее Соглашение является публичной офертой. Использование сайта подтверждает согласие с его условиями." wrapText="true" />
            </VBox>
        </content>
    </ScrollPane>
</AnchorPane>
